        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="my_noise_sound.stop();&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="my_noise_sound.stop()" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="sound_control" valType="code" updates="None" name="name"/>
