      <CodeComponent name="sound_control" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="from pygame import mixer&amp;#10;# Force 2 channels (Stereo) to fix the crash&amp;#10;mixer.init(frequency=44100, size=-16, channels=2, buffer=512)&amp;#10;# Load your sound file manually&amp;#10;my_noise_sound = mixer.Sound('cafe_noise.wav')" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="import {mixer} from 'pygame';&amp;#10;mixer.init({&quot;frequency&quot;: 44100, &quot;size&quot;: (- 16), &quot;channels&quot;: 2, &quot;buffer&quot;: 512});&amp;#10;my_noise_sound = new mixer.Sound(&quot;cafe_noise.wav&quot;);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((volume === 1)) {&amp;#10;    my_noise_sound.set_volume(1.0);&amp;#10;    my_noise_sound.play();&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if volume == 1:&amp;#10;    my_noise_sound.set_volume(1.0)&amp;#10;    my_noise_sound.play()" valType="extendedCode" updates="constant" name="Begin Routine"/>
